# ============================================================
# Iqraa Mobile — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# --- Backend API ---
# Option 1: Local (device and dev machine must be on same Wi-Fi)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8080/v1

# Option 2: Production backend (recommended for physical device testing)
# EXPO_PUBLIC_API_URL=https://api.iqraa.space/v1

# Option 3: Expo Tunnel (run `npx expo start --tunnel`, copy generated URL)
# EXPO_PUBLIC_API_URL=https://xxxxx.exp.direct/v1

EXPO_PUBLIC_API_URL=http://localhost:8080/v1
